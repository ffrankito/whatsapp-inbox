# Fase 1 del roadmap: modo demo — el inbox muestra datos de ejemplo, no habla con GHL/Kapso
DEMO_MODE=

# Fase 2 del roadmap: Kapso real conectado, todavía sin GHL — se guarda en memoria.
# No usar junto con DEMO_MODE (DEMO_MODE tiene prioridad si ambas están en true).
STANDALONE_MODE=

# GHL — Marketplace App (marketplace.gohighlevel.com > My Apps > Whatsapp inbox > Auth)
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_SHARED_SECRET_SSO=
GHL_REDIRECT_URI=
GHL_LOCATION_ID=

# Firma de la cookie de sesión propia
SESSION_SECRET=

# Postgres (Supabase) — solo para la tabla ghlInstalls (tokens de instalación por location)
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Kapso — HMAC de verificación del webhook
KAPSO_APP_SECRET=
KAPSO_VERIFY_TOKEN=

# Kapso — número Dealers
WA_DEALERS_PHONE_ID=
WA_DEALERS_API_KEY=
WA_DEALERS_PROVIDER_ID=

# Kapso — número Abonados
WA_ABONADOS_PHONE_ID=
WA_ABONADOS_API_KEY=
WA_ABONADOS_PROVIDER_ID=

# Kapso — número App Full Control
WA_FULLCONTROL_PHONE_ID=
WA_FULLCONTROL_API_KEY=
WA_FULLCONTROL_PROVIDER_ID=
